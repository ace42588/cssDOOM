{
  "name": "cssdoom",
  "version": "1.0.0",
  "description": "A DOOM engine implemented in CSS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:all": "concurrently -n server,vite -c blue,magenta \"npm:server\" \"npm:dev\"",
    "mcp:stdio": "node server/mcp/stdio-bridge.js",
    "test": "npm run test:protocol && npm run test:snapshot && npm run test:mcp:server && npm run test:admin",
    "test:admin": "node scripts/test-admin-rest.mjs",
    "test:protocol": "node scripts/test-protocol.mjs && node scripts/test-state-reset.mjs && node scripts/test-actor-shape.mjs && node scripts/test-entity-id.mjs && node scripts/test-possession-peers.mjs",
    "test:snapshot": "node scripts/test-snapshot-delta.mjs && node scripts/test-snapshot-reuse.mjs",
    "test:mcp:server": "node scripts/test-mcp-server.mjs"
  },
  "keywords": [
    "doom",
    "css",
    "game",
    "engine",
    "web"
  ],
  "author": "Niels Leenheer",
  "license": "GPL-2.0",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@mcp-b/webmcp-polyfill": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "gamecontroller.js": "^1.5.0",
    "jsonpath-plus": "^10.4.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}

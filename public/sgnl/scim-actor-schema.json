{
  "schemas": [
    "urn:ietf:params:scim:schemas:core:2.0:Schema"
  ],
  "id": "urn:cssdoom:params:scim:schemas:extension:actor:2.0:Actor",
  "name": "Actor",
  "description": "Runtime state for an AI-driven thing (enemy, barrel, etc.). One SCIM resource per active actor; `userName` is `actor:<MAP>:<mapThingIndex>`.",
  "attributes": [
    {
      "name": "actorId",
      "type": "string",
      "description": "Canonical asset id matching the SGNL map adapter entry (actor:<MAP>:<mapThingIndex>).",
      "required": true,
      "caseExact": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "server"
    },
    { "name": "mapName",       "type": "string",  "required": true,  "mutability": "readWrite", "returned": "default" },
    { "name": "thingIndex",    "type": "integer", "required": true,  "mutability": "readWrite", "returned": "default" },
    { "name": "mapThingIndex", "type": "integer", "required": true,  "mutability": "readWrite", "returned": "default" },
    { "name": "type",          "type": "integer", "required": true,  "mutability": "readWrite", "returned": "default" },
    { "name": "x",             "type": "decimal", "required": true,  "mutability": "readWrite", "returned": "default" },
    { "name": "y",             "type": "decimal", "required": true,  "mutability": "readWrite", "returned": "default" },
    { "name": "z",             "type": "decimal", "required": false, "mutability": "readWrite", "returned": "default" },
    { "name": "hp",            "type": "integer", "required": true,  "mutability": "readWrite", "returned": "default" },
    { "name": "isDead",        "type": "boolean", "required": true,  "mutability": "readWrite", "returned": "default" },
    { "name": "aiState",       "type": "string",  "required": false, "mutability": "readWrite", "returned": "default" },
    {
      "name": "possessedBy",
      "type": "string",
      "description": "Session id of the human operator currently possessing this actor, or null.",
      "required": false,
      "mutability": "readWrite",
      "returned": "default"
    },
    { "name": "updatedAt",     "type": "dateTime", "required": true, "mutability": "readWrite", "returned": "default" }
  ]
}

{
  "schemas": [
    "urn:ietf:params:scim:schemas:core:2.0:Schema"
  ],
  "id": "urn:cssdoom:params:scim:schemas:extension:state:2.0:GameState",
  "name": "GameState",
  "description": "CSS DOOM mutable game state persistence schema.",
  "attributes": [
    {
      "name": "mapName",
      "type": "string",
      "multiValued": false,
      "description": "Current map identifier (for example E1M1).",
      "required": true,
      "caseExact": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "correlationId",
      "type": "string",
      "multiValued": false,
      "description": "Shared correlation identifier linking player, game state, and session context.",
      "required": true,
      "caseExact": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "skillLevel",
      "type": "integer",
      "multiValued": false,
      "description": "Current gameplay skill level (1-5).",
      "required": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "thingCount",
      "type": "integer",
      "multiValued": false,
      "description": "Count of entries in state.things.",
      "required": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "projectileCount",
      "type": "integer",
      "multiValued": false,
      "description": "Count of active projectile entries.",
      "required": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "nextProjectileId",
      "type": "integer",
      "multiValued": false,
      "description": "Next allocated projectile identifier.",
      "required": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "doorState",
      "type": "complex",
      "multiValued": true,
      "description": "Door state entries keyed by sector index.",
      "required": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        {
          "name": "sectorIndex",
          "type": "integer",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "open",
          "type": "boolean",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "passable",
          "type": "boolean",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "keyRequired",
          "type": "string",
          "multiValued": false,
          "required": false,
          "mutability": "readWrite",
          "returned": "default"
        }
      ]
    },
    {
      "name": "liftState",
      "type": "complex",
      "multiValued": true,
      "description": "Lift entries keyed by sector index.",
      "required": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        {
          "name": "sectorIndex",
          "type": "integer",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "tag",
          "type": "integer",
          "multiValued": false,
          "required": false,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "currentHeight",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "targetHeight",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "lowerHeight",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "upperHeight",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "moving",
          "type": "boolean",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "oneWay",
          "type": "boolean",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        }
      ]
    },
    {
      "name": "crusherState",
      "type": "complex",
      "multiValued": true,
      "description": "Crusher entries keyed by sector index.",
      "required": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        {
          "name": "sectorIndex",
          "type": "integer",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "active",
          "type": "boolean",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "direction",
          "type": "integer",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "currentHeight",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "topHeight",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "crushHeight",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "damageTimer",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        }
      ]
    },
    {
      "name": "thingsSnapshot",
      "type": "string",
      "multiValued": false,
      "description": "JSON-encoded snapshot of state.things for full persistence.",
      "required": false,
      "caseExact": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "projectilesSnapshot",
      "type": "string",
      "multiValued": false,
      "description": "JSON-encoded snapshot of state.projectiles for full persistence.",
      "required": false,
      "caseExact": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "updatedAt",
      "type": "dateTime",
      "multiValued": false,
      "description": "Last persistence update time.",
      "required": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    }
  ]
}

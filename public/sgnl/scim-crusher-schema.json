{
  "schemas": [
    "urn:ietf:params:scim:schemas:core:2.0:Schema"
  ],
  "id": "urn:cssdoom:params:scim:schemas:extension:crusher:2.0:Crusher",
  "name": "Crusher",
  "description": "Runtime crusher state. `userName` is `crusher:<MAP>:<sectorIndex>` matching the SGNL map adapter `id`.",
  "attributes": [
    {
      "name": "crusherId",
      "type": "string",
      "description": "Canonical asset id (crusher:<MAP>:<sectorIndex>).",
      "required": true,
      "caseExact": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "server"
    },
    { "name": "mapName",       "type": "string",  "required": true, "mutability": "readWrite", "returned": "default" },
    { "name": "sectorIndex",   "type": "integer", "required": true, "mutability": "readWrite", "returned": "default" },
    { "name": "active",        "type": "boolean", "required": true, "mutability": "readWrite", "returned": "default" },
    { "name": "direction",     "type": "integer", "required": true, "mutability": "readWrite", "returned": "default" },
    { "name": "currentHeight", "type": "decimal", "required": true, "mutability": "readWrite", "returned": "default" },
    { "name": "topHeight",     "type": "decimal", "required": true, "mutability": "readWrite", "returned": "default" },
    { "name": "crushHeight",   "type": "decimal", "required": true, "mutability": "readWrite", "returned": "default" },
    { "name": "damageTimer",   "type": "decimal", "required": true, "mutability": "readWrite", "returned": "default" },
    { "name": "updatedAt",     "type": "dateTime", "required": true, "mutability": "readWrite", "returned": "default" }
  ]
}

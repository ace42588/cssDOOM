{
  "schemas": [
    "urn:ietf:params:scim:schemas:core:2.0:Schema"
  ],
  "id": "urn:cssdoom:params:scim:schemas:Player",
  "name": "Player",
  "description": "CSS DOOM player-session SCIM User extension. The User resource identity (userName, sessionId, displayName, active) is stable per session. The `controlledActorRef` block plus the nested `position`, `vitals`, `ammo`, `maxAmmo`, `inventory`, and `powerups` describe whichever actor the session is currently driving — marine, possessed monster, or null when spectating. Marine-only fields (ammo, maxAmmo, inventory.ownedWeapons, inventory.collectedKeys, powerups) are omitted when the session controls a non-marine body; consumers should tolerate their absence and branch on `controlledActorRef.type === 1` (marine) / `controlledActorRef.kind === 'marine'`.",
  "attributes": [
    {
      "name": "sessionId",
      "type": "string",
      "multiValued": false,
      "description": "Session id this player resource represents. `userName` is always `player:<sessionId>` so it matches the same id SGNL access evaluations cite.",
      "required": true,
      "caseExact": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "server"
    },
    {
      "name": "mapName",
      "type": "string",
      "multiValued": false,
      "description": "Current map identifier (for example E1M1).",
      "required": true,
      "caseExact": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "correlationId",
      "type": "string",
      "multiValued": false,
      "description": "Server-instance correlation id. Useful for joining to CAEP / evaluation logs.",
      "required": true,
      "caseExact": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "displayName",
      "type": "string",
      "multiValued": false,
      "description": "Player display label for SGNL/SCIM views.",
      "required": false,
      "caseExact": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    },
    {
      "name": "controlledActorRef",
      "type": "complex",
      "multiValued": false,
      "description": "Reference to the actor this session currently controls (marine, possessed monster, or null while spectating).",
      "required": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        {
          "name": "id",
          "type": "string",
          "multiValued": false,
          "description": "Canonical actor id: `actor:<slot>` or `thing:<index>`.",
          "required": true,
          "caseExact": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "type",
          "type": "integer",
          "multiValued": false,
          "description": "DOOM thing-type number (1 = marine, 3001 = Imp, etc.).",
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "kind",
          "type": "string",
          "multiValued": false,
          "description": "Broad category: 'marine' | 'enemy' | 'thing'.",
          "required": true,
          "caseExact": false,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "label",
          "type": "string",
          "multiValued": false,
          "description": "Human-readable label ('Marine', 'Imp', …).",
          "required": false,
          "mutability": "readWrite",
          "returned": "default"
        }
      ]
    },
    {
      "name": "position",
      "type": "complex",
      "multiValued": false,
      "description": "Controlled actor world-space position and orientation. Null when the session has no body.",
      "required": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        {
          "name": "x",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "y",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "z",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "angle",
          "type": "decimal",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        }
      ]
    },
    {
      "name": "vitals",
      "type": "complex",
      "multiValued": false,
      "description": "Controlled actor health/armor/death state. Populated for every session (spectators emit isDead=true with zero hp).",
      "required": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        {
          "name": "health",
          "type": "integer",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "maxHealth",
          "type": "integer",
          "multiValued": false,
          "required": false,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "armor",
          "type": "integer",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "armorType",
          "type": "integer",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "isDead",
          "type": "boolean",
          "multiValued": false,
          "required": true,
          "mutability": "readWrite",
          "returned": "default"
        }
      ]
    },
    {
      "name": "ammo",
      "type": "complex",
      "multiValued": false,
      "description": "Current ammo counts. Marine-only — omitted when controlling a monster body.",
      "required": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        { "name": "bullets", "type": "integer", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" },
        { "name": "shells",  "type": "integer", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" },
        { "name": "rockets", "type": "integer", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" },
        { "name": "cells",   "type": "integer", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" }
      ]
    },
    {
      "name": "maxAmmo",
      "type": "complex",
      "multiValued": false,
      "description": "Maximum ammo capacities. Marine-only — omitted when controlling a monster body.",
      "required": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        { "name": "bullets", "type": "integer", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" },
        { "name": "shells",  "type": "integer", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" },
        { "name": "rockets", "type": "integer", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" },
        { "name": "cells",   "type": "integer", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" }
      ]
    },
    {
      "name": "inventory",
      "type": "complex",
      "multiValued": false,
      "description": "Weapons, keys, and backpack state. Marine-only — omitted when controlling a monster body.",
      "required": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        { "name": "hasBackpack",   "type": "boolean", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" },
        { "name": "currentWeapon", "type": "integer", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" },
        {
          "name": "ownedWeapons",
          "type": "integer",
          "multiValued": true,
          "description": "Weapon slot numbers currently owned.",
          "required": false,
          "mutability": "readWrite",
          "returned": "default"
        },
        {
          "name": "collectedKeys",
          "type": "string",
          "multiValued": true,
          "description": "Collected key colors.",
          "required": false,
          "mutability": "readWrite",
          "returned": "default"
        }
      ]
    },
    {
      "name": "powerups",
      "type": "complex",
      "multiValued": true,
      "description": "Active powerups and remaining duration in seconds. Marine-only — omitted when controlling a monster body.",
      "required": false,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none",
      "subAttributes": [
        { "name": "name",             "type": "string",  "multiValued": false, "required": true, "caseExact": false, "mutability": "readWrite", "returned": "default" },
        { "name": "remainingSeconds", "type": "decimal", "multiValued": false, "required": true, "mutability": "readWrite", "returned": "default" }
      ]
    },
    {
      "name": "updatedAt",
      "type": "dateTime",
      "multiValued": false,
      "description": "Last persistence update time.",
      "required": true,
      "mutability": "readWrite",
      "returned": "default",
      "uniqueness": "none"
    }
  ]
}

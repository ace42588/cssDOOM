/**
 * {{SOR_DISPLAY_NAME}} — SGNL custom polling adapter (Node.js).
 *
 * Implements `sgnl.adapter.v1.Adapter.GetPage` using @grpc/grpc-js. Mirrors
 * the cssDOOM map adapter pattern (see server/sgnl/adapter/index.js).
 *
 * Generated by .cursor/skills/sgnl-sor.
 *
 * Env:
 *   SGNL_ADAPTER_VALID_TOKENS  Comma-separated shared secrets SGNL sends in
 *                              the gRPC `token` metadata. Required.
 *   SGNL_ADAPTER_PORT          Listen port (default 8081).
 *   SGNL_ADAPTER_SOR_TYPE      If set, GetPage enforces datasource.type match.
 *
 * Entities (external_id → upstream endpoint):
{{ENTITY_ROUTE_COMMENT}}
 */

import grpc from '@grpc/grpc-js';
import protoLoader from '@grpc/proto-loader';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const PROTO_PATH = path.join(__dirname, 'adapter.proto');

const SOR_TYPE = '{{SOR_TYPE}}';

/** Map of entity external_id → relative path on the upstream API. */
const ENTITY_ROUTES = {{ENTITY_ROUTES_JSON}};

function parseTokens() {
    return (process.env.SGNL_ADAPTER_VALID_TOKENS || '')
        .split(',')
        .map((t) => t.trim())
        .filter(Boolean);
}

function attributeValue(value, type) {
    if (value === null || value === undefined) return { null_value: {} };
    switch (type) {
        case 'ATTRIBUTE_TYPE_BOOL':
            return { bool_value: Boolean(value) };
        case 'ATTRIBUTE_TYPE_INT64':
            return { int64_value: String(Math.trunc(Number(value))) };
        case 'ATTRIBUTE_TYPE_DOUBLE':
            return { double_value: Number(value) };
        case 'ATTRIBUTE_TYPE_DATE_TIME':
            return {
                datetime_value: {
                    timestamp: { seconds: String(Math.floor(new Date(value).getTime() / 1000)), nanos: 0 },
                    timezone_offset: 0,
                },
            };
        default:
            return { string_value: String(value) };
    }
}

function rowsToObjects(rows, attributes) {
    return rows.map((row) => ({
        attributes: attributes.map((attr) => ({
            id: attr.id,
            values: [attributeValue(row[attr.external_id], attr.type)],
        })),
        child_objects: [],
    }));
}

async function fetchUpstream(req, route) {
    const url = `${req.datasource.address.replace(/\/$/, '')}/${route.replace(/^\//, '')}`;
    const headers = { Accept: 'application/json' };
    const auth = req.datasource.auth || {};
    if (auth.basic) {
        const token = Buffer.from(`${auth.basic.username}:${auth.basic.password}`).toString('base64');
        headers.Authorization = `Basic ${token}`;
    } else if (auth.http_authorization) {
        headers.Authorization = auth.http_authorization;
    }
    const res = await fetch(url, { headers });
    if (!res.ok) {
        const body = await res.text().catch(() => '');
        throw new Error(`upstream ${res.status} ${res.statusText}: ${body.slice(0, 200)}`);
    }
    return res.json();
}

async function handleGetPage(req) {
    if (SOR_TYPE && req.datasource?.type && req.datasource.type !== SOR_TYPE) {
        return { error: { message: `Unsupported datasource type "${req.datasource.type}"`, code: 2 } };
    }
    const entityExt = req.entity?.external_id;
    const route = ENTITY_ROUTES[entityExt];
    if (!route) {
        return {
            error: {
                message: `Entity external_id "${entityExt}" not supported; expected one of: ${Object.keys(ENTITY_ROUTES).join(', ')}`,
                code: 4,
            },
        };
    }
    try {
        const payload = await fetchUpstream(req, route);
        const rows = Array.isArray(payload) ? payload : (payload.items || payload.results || []);
        return {
            success: {
                objects: rowsToObjects(rows, req.entity.attributes || []),
                next_cursor: '',
            },
        };
    } catch (err) {
        return { error: { message: err.message, code: 10 } };
    }
}

function makeGetPageHandler(validTokens) {
    return async function GetPage(call, callback) {
        try {
            const meta = call.metadata.get('token');
            const reqToken = meta && meta.length ? meta[0] : '';
            if (!validTokens.includes(reqToken) || !call.request?.entity?.id || !call.request?.datasource?.id) {
                return callback(null, { error: { message: 'Invalid GetPageRequest', code: 1 } });
            }
            const result = await handleGetPage(call.request);
            if (result.error) return callback(null, { error: result.error });
            callback(null, { success: result.success });
        } catch (err) {
            console.error('[{{SOR_TYPE}}] GetPage error:', err);
            callback(null, { error: { message: err.message, code: 10 } });
        }
    };
}

export async function startAdapter() {
    const validTokens = parseTokens();
    if (validTokens.length === 0) {
        console.warn('[{{SOR_TYPE}}] SGNL_ADAPTER_VALID_TOKENS not set — adapter disabled');
        return null;
    }
    const packageDefinition = protoLoader.loadSync(PROTO_PATH, {
        keepCase: true, longs: String, enums: String, defaults: true, oneofs: true,
    });
    const proto = grpc.loadPackageDefinition(packageDefinition).sgnl.adapter.v1;
    const server = new grpc.Server();
    server.addService(proto.Adapter.service, { GetPage: makeGetPageHandler(validTokens) });
    const port = Number(process.env.SGNL_ADAPTER_PORT) || 8081;
    return new Promise((resolve, reject) => {
        server.bindAsync(`0.0.0.0:${port}`, grpc.ServerCredentials.createInsecure(), (err) => {
            if (err) return reject(err);
            console.log(`[{{SOR_TYPE}}] gRPC listening on :${port}`);
            resolve(server);
        });
    });
}

if (import.meta.url === `file://${process.argv[1]}`) {
    startAdapter().catch((err) => { console.error(err); process.exit(1); });
}

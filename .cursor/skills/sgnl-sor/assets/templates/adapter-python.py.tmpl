from __future__ import annotations

import base64
import json
import os
import sys
from concurrent import futures
from typing import Any
from urllib import error as urlerror
from urllib import request as urlrequest

import grpc

import adapter_pb2 as pb
import adapter_pb2_grpc as pb_grpc


SOR_TYPE = "{{SOR_TYPE}}"
ENTITY_ROUTES: dict[str, str] = {{ENTITY_ROUTES_JSON}}


def _valid_tokens() -> list[str]:
    raw = os.environ.get("SGNL_ADAPTER_VALID_TOKENS", "")
    return [t.strip() for t in raw.split(",") if t.strip()]


def _attr_value(value: Any, attr_type: str) -> pb.AttributeValue:
    if value is None:
        return pb.AttributeValue(null_value=pb.google_dot_protobuf_dot_empty__pb2.Empty())
    if attr_type == "ATTRIBUTE_TYPE_BOOL":
        return pb.AttributeValue(bool_value=bool(value))
    if attr_type == "ATTRIBUTE_TYPE_INT64":
        return pb.AttributeValue(int64_value=int(value))
    if attr_type == "ATTRIBUTE_TYPE_DOUBLE":
        return pb.AttributeValue(double_value=float(value))
    return pb.AttributeValue(string_value=str(value))


def _rows_to_objects(rows: list[dict], attributes) -> list[pb.Object]:
    objects: list[pb.Object] = []
    for row in rows:
        attrs = []
        for cfg in attributes:
            value = row.get(cfg.external_id)
            attrs.append(pb.Attribute(id=cfg.id, values=[_attr_value(value, pb.AttributeType.Name(cfg.type))]))
        objects.append(pb.Object(attributes=attrs))
    return objects


def _fetch_upstream(req: pb.GetPageRequest, route: str) -> list[dict]:
    base = (req.datasource.address or "").rstrip("/")
    url = f"{base}/{route.lstrip('/')}"
    http_req = urlrequest.Request(url, headers={"Accept": "application/json"})
    if req.datasource.auth.WhichOneof("auth_mechanism") == "basic":
        creds = f"{req.datasource.auth.basic.username}:{req.datasource.auth.basic.password}"
        token = base64.b64encode(creds.encode()).decode()
        http_req.add_header("Authorization", f"Basic {token}")
    elif req.datasource.auth.WhichOneof("auth_mechanism") == "http_authorization":
        http_req.add_header("Authorization", req.datasource.auth.http_authorization)
    try:
        with urlrequest.urlopen(http_req, timeout=30) as resp:
            payload = json.loads(resp.read().decode())
    except urlerror.HTTPError as exc:
        raise RuntimeError(f"upstream {exc.code} {exc.reason}") from exc
    if isinstance(payload, list):
        return payload
    if isinstance(payload, dict):
        return payload.get("items") or payload.get("results") or []
    return []


class AdapterServicer(pb_grpc.AdapterServicer):
    def __init__(self, valid_tokens: list[str]) -> None:
        self._valid_tokens = valid_tokens

    def GetPage(self, request: pb.GetPageRequest, context: grpc.ServicerContext) -> pb.GetPageResponse:
        meta = dict(context.invocation_metadata())
        if meta.get("token", "") not in self._valid_tokens:
            return pb.GetPageResponse(error=pb.Error(message="Invalid token", code=pb.ERROR_CODE_INVALID_PAGE_REQUEST_CONFIG))
        if SOR_TYPE and request.datasource.type and request.datasource.type != SOR_TYPE:
            return pb.GetPageResponse(error=pb.Error(message=f"Unsupported type {request.datasource.type!r}", code=pb.ERROR_CODE_INVALID_DATASOURCE_CONFIG))
        route = ENTITY_ROUTES.get(request.entity.external_id)
        if not route:
            return pb.GetPageResponse(error=pb.Error(
                message=f"Entity {request.entity.external_id!r} not supported; expected one of: {sorted(ENTITY_ROUTES)}",
                code=pb.ERROR_CODE_INVALID_ENTITY_CONFIG,
            ))
        try:
            rows = _fetch_upstream(request, route)
            objects = _rows_to_objects(rows, request.entity.attributes)
            return pb.GetPageResponse(success=pb.Page(objects=objects, next_cursor=""))
        except Exception as exc:  # noqa: BLE001
            return pb.GetPageResponse(error=pb.Error(message=str(exc), code=pb.ERROR_CODE_DATASOURCE_FAILED))


def serve() -> None:
    valid_tokens = _valid_tokens()
    if not valid_tokens:
        print("[{{SOR_TYPE}}] SGNL_ADAPTER_VALID_TOKENS not set — adapter disabled", file=sys.stderr)
        return
    port = int(os.environ.get("SGNL_ADAPTER_PORT", "8081"))
    server = grpc.server(futures.ThreadPoolExecutor(max_workers=8))
    pb_grpc.add_AdapterServicer_to_server(AdapterServicer(valid_tokens), server)
    server.add_insecure_port(f"0.0.0.0:{port}")
    server.start()
    print(f"[{{SOR_TYPE}}] gRPC listening on :{port}")
    server.wait_for_termination()


if __name__ == "__main__":
    serve()

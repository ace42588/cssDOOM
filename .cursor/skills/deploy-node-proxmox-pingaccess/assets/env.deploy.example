# deploy-node-proxmox-pingaccess — environment.
#
# Copy to ./.deploy.env, fill in, then `set -a; . ./.deploy.env; set +a`
# before invoking the skill. Add ./.deploy.env to .gitignore.
#
# Anything left blank disables the conditional path that needs it; the
# skill stops with a clear message if a required variable is missing.

# --- Proxmox VE (always required) ---
PVE_HOST=pve01.lab.example.com
PVE_NODE=pve01
PVE_SSH_USER=root
PVE_STORAGE=local-lvm
PVE_BRIDGE=vmbr0

# --- LXC target (required when TARGET_KIND=lxc) ---
PVE_LXC_TEMPLATE=local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst
PVE_LXC_PASSWORD=
PVE_SSH_PUBKEY_PATH=~/.ssh/id_ed25519.pub

# --- VM target (required when TARGET_KIND=vm) ---
PVE_VM_TEMPLATE_ID=9000
PVE_VM_CLOUDINIT_USER=deploy
PVE_VM_SNIPPET_STORAGE=local

# --- Existing-host target (required when TARGET_KIND=existing) ---
DEPLOY_HOST=
DEPLOY_SSH_USER=root

# --- PingAccess (always required) ---
PA_ADMIN_HOST=https://pa-admin.example.com:9000
PA_ADMIN_USER=Administrator
PA_ADMIN_PASS=
PA_INSECURE_TLS=1   # set to 0 once you trust the admin cert

# --- Defaults the agent inherits unless the brief overrides them ---
PUBLIC_HOSTNAME=
PA_VHOST_PORT=443
APPLICATION_CONTEXT_ROOT=/

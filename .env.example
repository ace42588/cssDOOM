# cssDOOM server-side configuration.
#
# Anything left blank simply disables that channel — the engine still
# runs vanilla. Only `SGNL_ADAPTER_VALID_TOKENS` is required to bring
# up the gRPC adapter.

# --- multiplayer server (built-ins; usually leave alone) ---
# PORT=8787
# IDLE_WARNING_MS=30000
# IDLE_DROP_MS=60000
# SGNL_ADAPTER_PORT=8081

# --- MCP (server-side AI agent interface; embedded in the game server) ---
# Streamable HTTP MCP endpoint. Used by the stdio bridge (`npm run mcp:stdio`)
# and any remote/cloud MCP client. Default: http://localhost:8787/mcp.
# MCP_HTTP_URL=http://localhost:8787/mcp
# Optional bearer token; when set, the server requires
# `Authorization: Bearer <token>` on every /mcp request and the stdio bridge
# forwards it. Leave blank for an open endpoint (recommended only on loopback).
# MCP_BEARER_TOKEN=

# --- SGNL Access Evaluations (server-side door gating) ---
SGNL_EVAL_URL=
SGNL_EVAL_TOKEN=
SGNL_DEFAULT_PRINCIPAL_ID=

# --- CAEP / SSF (session-established push) ---
CAEP_RECEIVER_URL=
CAEP_BEARER_TOKEN=
CAEP_SET_ISS=
CAEP_SET_AUD=
CAEP_SUBJECT_EMAIL=

# --- SCIM 2.0 push (player sessions only) ---
# SGNL's SCIM adapter only accepts /Users and /Groups, so this channel
# mirrors connected player sessions as SCIM Users. Game-entity state
# (doors/lifts/crushers/pickups/keys/actors) goes through Event Push
# below, not here. SCIM_PUSH_URL is the base URL; SGNL appends /Users.
SCIM_PUSH_URL=
SCIM_BEARER_TOKEN=

# --- SGNL Event Push (non-player game state) ---
# Full endpoint URL SGNL issues at SoR creation for events-sor.yaml:
#   https://{client}.sgnlapis.cloud/events/custom/v1/{datasourceId}
# Leave blank to disable event emission.
SGNL_EVENTS_URL=
SGNL_EVENTS_TOKEN=

# --- SGNL gRPC adapter (System of Record for the running map) ---
# Comma-separated bearer tokens accepted in the gRPC `token` metadata.
SGNL_ADAPTER_VALID_TOKENS=
# Optional: enforce that GetPage requests target this datasource type.
# SGNL_ADAPTER_SOR_TYPE=
# GRPC_MAX_MESSAGE_LENGTH=268435456

# --- docker compose host bindings (override only if needed) ---
# WEB_BIND=127.0.0.1
# WEB_PORT=8080
# GAME_BIND=127.0.0.1
# GAME_PORT=8787
# ADAPTER_BIND=127.0.0.1
# ADAPTER_PORT=8081
# EDGE_BIND=0.0.0.0
# EDGE_PORT=8090
